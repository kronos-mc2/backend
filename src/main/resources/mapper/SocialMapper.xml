<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="hr.kronos.backend.social.persistence.SocialMapper">

  <select id="findFriends" resultType="hr.kronos.backend.social.persistence.FriendRow">
    SELECT
      id,
      name,
      status_hr,
      status_en
    FROM friends
    ORDER BY name ASC
  </select>

</mapper>
