<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="hr.kronos.backend.messages.persistence.MessageMapper">

  <select id="findConversations" resultType="hr.kronos.backend.messages.persistence.ConversationRow">
    SELECT
      id,
      contact,
      last_message_hr,
      last_message_en,
      time_label
    FROM conversations
    ORDER BY updated_at DESC, id ASC
  </select>

</mapper>
