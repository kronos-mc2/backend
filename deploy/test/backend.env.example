POSTGRES_DB=gik_test
POSTGRES_USER=gik
POSTGRES_PASSWORD=change-this-db-password

DB_URL=jdbc:postgresql://postgres:5432/gik_test
DB_USERNAME=gik
DB_PASSWORD=change-this-db-password

AUTH_JWT_SECRET=change-this-to-at-least-64-random-characters-before-deploy
AUTH_JWT_EXPIRATION_SECONDS=2592000
# Use the same Web client ID from frontend EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID.
# Do not put the Android client ID here unless Google starts issuing id tokens with that audience.
AUTH_GOOGLE_CLIENT_IDS=your-test-web-google-client-id.apps.googleusercontent.com
AUTH_APPLE_CLIENT_ID=

MINIO_ROOT_USER=gikminio
MINIO_ROOT_PASSWORD=change-this-minio-password
APP_STORAGE_PROVIDER=s3
APP_STORAGE_ENDPOINT=http://minio:9000
APP_STORAGE_REGION=auto
APP_STORAGE_BUCKET=gik-event-media
# Uploaded event media is served through authenticated backend routes.
# Keep this empty unless you intentionally need legacy direct object URLs for non-private external tooling.
APP_STORAGE_PUBLIC_BASE_URL=
APP_STORAGE_ACCESS_KEY=gikminio
APP_STORAGE_SECRET_KEY=change-this-minio-password
APP_STORAGE_PATH_STYLE_ACCESS=true
APP_STORAGE_MAX_TOTAL_BYTES=10737418240
APP_STORAGE_MAX_FILE_BYTES=5242880
