POSTGRES_DB=gik_test
POSTGRES_USER=gik
POSTGRES_PASSWORD=change-this-db-password

DB_URL=jdbc:postgresql://postgres:5432/gik_test
DB_USERNAME=gik
DB_PASSWORD=change-this-db-password

AUTH_JWT_SECRET=change-this-to-at-least-64-random-characters-before-deploy
AUTH_JWT_EXPIRATION_SECONDS=2592000
# Use the same Web client ID from frontend EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID.
# Do not put the Android client ID here unless Google starts issuing id tokens with that audience.
AUTH_GOOGLE_CLIENT_IDS=your-test-web-google-client-id.apps.googleusercontent.com
AUTH_APPLE_CLIENT_ID=
